# Groq API key — free at https://console.groq.com (no credit card needed)
GROQ_API_KEY=gsk_your-groq-key-here

# Optional: add more free keys (comma-separated) for round-robin rotation.
# Each free Groq key gives 6,000 TPM. 5 keys = 30,000 TPM effective capacity.
# Get more free keys at https://console.groq.com → API Keys → Create key
GROQ_API_KEYS=gsk_second-key,gsk_third-key,gsk_fourth-key,gsk_fifth-key

# Models (defaults work out of the box — no need to change)
GROQ_MODEL=llama-3.1-8b-instant
GROQ_CLASSIFY_MODEL=llama-3.1-8b-instant
LLM_PROVIDER=groq

LOG_LEVEL=INFO
